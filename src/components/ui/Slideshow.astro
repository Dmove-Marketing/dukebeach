---
import Img from './Img.astro';

interface SlideImage {
  src: string;
  alt: string;
  objectPosition?: string;
}

interface Props {
  images: SlideImage[];
  /** Segundos que cada foto fica visível */
  interval?: number;
  /** Duração do crossfade em segundos */
  transition?: number;
  class?: string;
  priority?: boolean;
  /** object-position padrão para todas as imagens (ex: "top", "center 20%") */
  objectPosition?: string;
}

const {
  images,
  interval = 6,
  transition = 1.5,
  class: className,
  priority = false,
  objectPosition = 'center',
} = Astro.props;

const n = images.length;
if (n === 0) return;

const uid = `sl${Math.random().toString(36).slice(2, 8)}`;
const total = n * interval;
const holdPct = ((interval - transition) / total * 100).toFixed(2);
const fadePct  = (interval / total * 100).toFixed(2);

const css = `
@keyframes ${uid} {
  0%         { opacity: 0; }
  1%         { opacity: 1; }
  ${holdPct}% { opacity: 1; }
  ${fadePct}% { opacity: 0; }
  100%       { opacity: 0; }
}
.${uid}-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  animation-name: ${uid};
  animation-duration: ${total}s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-fill-mode: both;
}
.${uid}-slide img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: ${objectPosition};
}`;
---

{n === 1 ? (
  <Img src={images[0].src} alt={images[0].alt} class={`fill-img${className ? ` ${className}` : ''}`} priority={priority} />
) : (
  <>
    <Fragment set:html={`<style>${css}</style>`} />
    {images.map((img, i) => (
      <div class={`${uid}-slide`} style={`animation-delay:${i * interval}s`}>
        <Img
          src={img.src}
          alt={img.alt}
          priority={i === 0 && priority}
          style={img.objectPosition ? `object-position:${img.objectPosition}` : undefined}
        />
      </div>
    ))}
  </>
)}
